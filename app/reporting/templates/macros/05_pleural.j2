{# --- Indwelling Tunneled Pleural Catheter Placement - CPT 32550 --- #}
{% macro tpc_placement(side=None, intercostal_space=None, location=None, tunnel_length_cm=None, exit_site_location=None, volume_removed=None, fluid_appearance=None, lidocaine_volume=None, us_findings=None, pleural_pressures=None, drainage_device='Capped', suction=false, specimens=None, cxr_ordered=true, sutured=true) %}
